{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "module": "esnext",
    "types": ["node", "react", "react-dom"],
    "plugins": [{ "name": "next" }],
    "paths": {
      "@covenant/core": ["../../packages/core/src/index.ts"],
      "@covenant/providers": ["../../packages/providers/src/index.ts"],
      "@covenant/agent": ["../../packages/agent/src/index.ts"],
      "@covenant/adapters": ["../../packages/adapters/src/index.ts"],
      "@covenant/sample-data": ["../../packages/sample-data/src/index.ts"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/adapters/src/pdf-parse.d.ts"
  ],
  "exclude": ["node_modules"]
}
