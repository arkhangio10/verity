# ── Vultr Serverless Inference (the AI brain) ────────────────────────────────
# All LLM inference and embedding-based retrieval go through Vultr's
# OpenAI-compatible endpoint. Leave VULTR_API_KEY empty to run fully offline:
# the app falls back to the deterministic planner and the lexical retriever,
# and the demo still works end-to-end on the bundled sample data.
VULTR_API_KEY=
VULTR_INFERENCE_BASE_URL=https://api.vultrinference.com/v1

# Model ids depend on your Vultr account. List them with:
#   curl -H "Authorization: Bearer $VULTR_API_KEY" $VULTR_INFERENCE_BASE_URL/models
VULTR_CHAT_MODEL=llama-3.3-70b-instruct-fp8
# The VultronRetriever needs an embedding-capable model. If unset, document
# retrieval uses the local lexical (BM25) fallback.
VULTR_EMBED_MODEL=

# ── Agent behaviour ──────────────────────────────────────────────────────────
# scripted (default): deterministic, auditable control flow; the LLM enriches
#   plan wording, reasoning notes and memo prose when configured.
# model: fully model-driven ReAct tool loop (requires VULTR_API_KEY).
AGENT_LOOP_MODE=scripted

# ── Peru adapter (live path; the demo uses bundled fixtures) ─────────────────
SMV_BASE_URL=https://www.smv.gob.pe
